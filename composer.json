{
    "name": "vimatech/laravel-invitation",
    "description": "Generic email-based invitations for Laravel.",
    "keywords": ["laravel", "invitation", "email", "invite"],
    "license": "MIT",
    "authors": [
        {
            "name": "Adel Zemzemi",
            "email": "hello@adelzemzemi.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/notifications": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Vimatech\\Invitation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vimatech\\Invitation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vimatech\\Invitation\\InvitationServiceProvider"
            ],
            "aliases": {
                "Invitations": "Vimatech\\Invitation\\Facades\\Invitations"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    }
}
